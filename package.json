{
  "name": "bcurl",
  "version": "2.4.0",
  "description": "Like curl, but returns a browser-rendered screenshot instead of source code",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "bcurl": "bin/bcurl.js"
  },
  "files": [
    "dist/",
    "bin/",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/christianbuerckert/bcurl.git"
  },
  "homepage": "https://github.com/christianbuerckert/bcurl",
  "author": "Christian Buerckert <christian@buerckert.eu>",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "postinstall": "npx playwright install chromium"
  },
  "keywords": [
    "curl",
    "screenshot",
    "browser",
    "headless",
    "cli",
    "playwright",
    "mcp",
    "scraping",
    "visual-testing"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^13.1.0",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  }
}
